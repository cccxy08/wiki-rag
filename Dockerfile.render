FROM python:3.10-slim

WORKDIR /app

COPY requirements.hf.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .
COPY wiki-data/ /app/wiki-data/
COPY start.render.sh /app/start.sh

RUN chmod +x /app/start.sh

ENV HOST=0.0.0.0
ENV PORT=10000
ENV LLM_PROVIDER=minimax
ENV MINIMAX_BASE_URL=https://api.minimax.chat/v1
ENV MINIMAX_API_KEY=sk-cp-1Lao29cuXpD8O0do4tz1CJyuObwjdeOy9cgeGOJnYa-IRlk_AxVHPRUuSzNCapr0uOKXWhiVm8moOvBmQbhExr9hjPFydDNC1FFULo1DdLw1CFckQMcIeO4
ENV MINIMAX_MODEL=MiniMax-Text-01
ENV MINIMAX_MULTIMODAL_MODEL=MiniMax-VL-01
ENV EMBEDDING_PROVIDER=zhipu
ENV ZHIPU_EMBEDDING_MODEL=embedding-3
ENV RERANKER_ENABLED=false
ENV RENDER=true
ENV DINGTALK_ENABLED=false
ENV DINGTALK_MODE=webhook
ENV DINGTALK_DRIVE_PROXY_URL=http://203.104.35.193/dingdrive
ENV DINGTALK_DRIVE_PROXY_TOKEN=dingdrive-proxy-2026
ENV DINGTALK_DRIVE_USER_ID=1
EXPOSE 10000

CMD ["/app/start.sh"]
