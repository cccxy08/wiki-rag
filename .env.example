# LLM Provider 配置
# 可选: ollama / openai / zhipu
LLM_PROVIDER=ollama

# Ollama 配置（本地模型）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI 配置（可选切换）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# 智谱配置（可选切换）
# ZHIPU_API_KEY=xxx
# ZHIPU_MODEL=glm-4

# Embedding 配置
EMBEDDING_MODEL=BAAI/bge-small-zh

# 向量库配置
CHROMA_PERSIST_DIR=./chroma_db

# Wiki 数据目录
WIKI_DATA_DIR=../wiki-data

# 切片策略
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 服务配置
HOST=0.0.0.0
PORT=8000
