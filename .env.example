# LLM Provider 配置
# 可选: ollama / openai / zhipu / minimax
LLM_PROVIDER=minimax

# Ollama 配置（本地模型）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI 配置（可选切换）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# 智谱配置（可选切换）
# ZHIPU_API_KEY=xxx
# ZHIPU_MODEL=glm-4

# MiniMax 配置（推荐，多模态支持）
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_MULTIMODAL_MODEL=MiniMax-VL-01
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ===== Embedding 配置 =====
# 可选: local / zhipu / openai
# - local: 本地 SentenceTransformer，需 ~500MB 内存加载 bge-small-zh
# - zhipu: 智谱 Embedding API（推荐，零内存，¥0.5/百万token）
# - openai: OpenAI Embedding API（零内存，$0.02/百万token）
EMBEDDING_PROVIDER=zhipu

# local 模式下的模型配置
# EMBEDDING_MODEL=BAAI/bge-small-zh
# EMBEDDING_DEVICE=cpu

# 智谱 Embedding 模型（EMBEDDING_PROVIDER=zhipu 时生效）
ZHIPU_EMBEDDING_MODEL=embedding-3

# OpenAI Embedding 模型（EMBEDDING_PROVIDER=openai 时生效）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Reranker 配置 =====
RERANKER_ENABLED=false
# RERANKER_MODEL_PATH=./.models/BAAI/bge-reranker-base

# ===== 向量库配置 =====
CHROMA_PERSIST_DIR=./chroma_db

# ===== Wiki 数据目录 =====
WIKI_DATA_DIR=../wiki-data

# ===== 切片策略 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== 安全配置 =====
AUTH_ENABLED=false
API_KEYS=[]
CORS_ORIGINS=
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ADMIN_PER_MINUTE=20

# ===== 日志配置 =====
LOG_FORMAT=json
LOG_LEVEL=INFO

# ===== 缓存配置 =====
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379/0

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000

# ===== 钉钉配置 =====
DINGTALK_ENABLED=false
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
DINGTALK_MODE=webhook
DINGTALK_ADMIN_IDS=
DINGTALK_ADMIN_GROUP_WEBHOOK=

# ===== 钉钉云盘配置 =====
# ===== 钉钉云盘配置 =====
DINGTALK_DRIVE_SPACE_ID=
DINGTALK_DRIVE_FOLDER_ID=
DINGTALK_DRIVE_SYNC_INTERVAL_HOURS=72

# ===== 知识提取配置 =====
KNOWLEDGE_EXTRACT_INTERVAL_HOURS=72
KNOWLEDGE_EXTRACT_MAX_CONVERSATIONS=50
