# LLM Provider 配置
# 可选: ollama / openai / zhipu
LLM_PROVIDER=ollama

# Ollama 配置（本地模型）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# OpenAI 配置（可选切换）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

# 智谱配置（可选切换）
# ZHIPU_API_KEY=xxx
# ZHIPU_MODEL=glm-4

# ===== Embedding 配置 =====
# 可选: local / zhipu / openai
# - local: 本地 SentenceTransformer，需 ~500MB 内存加载 bge-small-zh
# - zhipu: 智谱 Embedding API（推荐，零内存，¥0.5/百万token）
# - openai: OpenAI Embedding API（零内存，$0.02/百万token）
EMBEDDING_PROVIDER=zhipu

# local 模式下的模型配置
# EMBEDDING_MODEL=BAAI/bge-small-zh
# EMBEDDING_DEVICE=cpu

# 智谱 Embedding 模型（EMBEDDING_PROVIDER=zhipu 时生效）
ZHIPU_EMBEDDING_MODEL=embedding-3

# OpenAI Embedding 模型（EMBEDDING_PROVIDER=openai 时生效）
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Reranker 配置 =====
# 关闭可省 ~1.2GB 内存，BM25+向量混合检索已够用
# 后续需要可启用，或改用 API Reranker（Jina/Cohere）
RERANKER_ENABLED=false
# RERANKER_MODEL_PATH=./.models/BAAI/bge-reranker-base

# ===== 向量库配置 =====
CHROMA_PERSIST_DIR=./chroma_db

# ===== Wiki 数据目录 =====
WIKI_DATA_DIR=../wiki-data

# ===== 切片策略 =====
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
